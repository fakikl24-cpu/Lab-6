library(tidyverse)
library(dsbox)
states <- read_csv("data/states.csv")
dn <- read_csv("data/dennys.csv")
lq <- read_csv("data/laquinta.csv")
dn_ak <- dn %>%
filter(state == "AK")
nrow(dn_ak)
lq_ak <- lq %>%
filter(state == "AK")
nrow(lq_ak)
nrow(dn_ak) * nrow(lq_ak)
dn_lq_ak <- full_join(dn_ak, lq_ak,
by = "state"
)
dn_lq_ak
nrow(dn_lq_ak)
haversine <- function(long1, lat1, long2, lat2, round =3) {
long1 <- long1 * pi / 180
lat2 <- lat1 * pi /180
long2 <- long2 * pi /180
lat2 <- lat2 * pi /180
R <- 6371
a <- sin((lat2 - lat1) / 2)^2 + cos(lat1) * cos(lat2) * sin((long2 - long1) /2)^2
d <- R * 2 * asin(sqrt(a))
return(round(d, round))
haversine <- function(long1, lat1, long2, lat2, round = 3) {
long1 <- long1 * pi / 180
lat2 <- lat1 * pi /180
long2 <- long2 * pi /180
lat2 <- lat2 * pi /180
R <- 6371
a <- sin((lat2 - lat1) / 2)^2 + cos(lat1) * cos(lat2) * sin((long2 - long1) /2)^2
d <- R * 2 * asin(sqrt(a))
return(round(d, round))
}
